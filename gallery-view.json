{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/v2/tile-formatting.schema.json",
  "hideSelection": true,
  "height": 150,
  "width": 210,
  "formatter": {
    "elmType": "a",
    "attributes": {
      "class": "ms-fontColor-neutralTertiaryAlt ms-bgColor-white",
      "href": "[$Link]",
      "target": "_blank"
    },
    "style": {
      "display": "flex",
      "flex-direction": "column",
      "width": "195px",
      "margin": "5px",
      "border": "0.5px solid",
      "border-radius": "12px",
      "overflow": "hidden",
      "position": "relative",
      "cursor": "pointer",
      "text-decoration": "none"
    },
    "children": [
      {
        "elmType": "div",
        "attributes": {
          "class": "ms-bgColor-themeLighter"
        },
        "style": {
          "display": "flex",
          "justify-content": "center",
          "align-items": "center",
          "height": "70px",
          "width": "100%",
          "position": "relative"
        },
        "children": [
          {
            "elmType": "div",
            "txtContent": "[$Icon]",
            "attributes": {
              "class": "ms-fontSize-32"
            }
          },
          {
            "elmType": "div",
            "txtContent": "[$Status]",
            "style": {
              "position": "absolute",
              "top": "6px",
              "right": "6px",
              "font-size": "10px",
              "font-weight": "600",
              "padding": "2px 6px",
              "border-radius": "20px",
              "background-color": "=if([$Status] == '未着手', '#D13438', if([$Status] == '進行中', '#107C10', if([$Status] == '完了', '#0078D4', '#BA7517')))",
              "color": "#ffffff",
              "white-space": "nowrap",
              "max-width": "80px",
              "overflow": "hidden",
              "text-overflow": "ellipsis"
            }
          }
        ]
      },
      {
        "elmType": "div",
        "style": {
          "display": "flex",
          "flex-direction": "column",
          "padding": "8px 10px 10px",
          "gap": "3px"
        },
        "children": [
          {
            "elmType": "div",
            "txtContent": "[$Title]",
            "attributes": {
              "class": "ms-fontColor-themePrimary ms-fontWeight-bold ms-fontSize-16"
            },
            "style": {
              "line-height": "1.4",
              "overflow": "hidden",
              "display": "-webkit-box",
              "-webkit-line-clamp": "2",
              "-webkit-box-orient": "vertical"
            }
          },
          {
            "elmType": "div",
            "style": {
              "height": "3px",
              "width": "100%",
              "background-color": "#e9e9e9",
              "border-radius": "2px",
              "margin-top": "6px",
              "margin-bottom": "2px",
              "overflow": "hidden"
            },
            "children": [
              {
                "elmType": "div",
                "style": {
                  "height": "100%",
                  "width": "=Number([$Progress]) + '%'",
                  "border-radius": "2px",
                  "background-color": "=if(Number([$Progress]) >= 80, '#639922', if(Number([$Progress]) >= 40, '#185FA5', '#BA7517'))"
                }
              }
            ]
          },
          {
            "elmType": "div",
            "txtContent": "=Number([$Progress]) + '% 完了'",
            "attributes": {
              "class": "ms-fontColor-neutralSecondary"
            },
            "style": {
              "font-size": "10px"
            }
          }
        ]
      }
    ]
  }
}
